# EvalScope GUI 环境变量模板
# 复制为 .env 并按需修改：cp .env.example .env

# === 本地开发（不使用 Docker 时）===
# DATABASE_URL=postgresql+asyncpg://evalscope:evalscope@localhost:6001/evalscope
# DATABASE_URL_SYNC=postgresql://evalscope:evalscope@localhost:6001/evalscope

# === 存储 / Storage ===
# STORAGE_BACKEND=local
# STORAGE_ROOT=data

# === S3 存储（可选）===
# STORAGE_BACKEND=s3
# S3_BUCKET=evalscope
# S3_ENDPOINT_URL=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin

# === 注意 ===
# 模型 API Key 不在此配置。
# 请通过前端界面 → 模型管理 → 添加模型时填写 endpoint、api_key、model_name。
# 数据安全存储在数据库中。
